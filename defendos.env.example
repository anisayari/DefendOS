# Copy this file to defendos.env and fill the values.

# Where DefendOS sends scheduled alerts.
DEFENDOS_ALERT_EMAIL_TO=security@example.com

# Mailbox that receives your commands.
DEFENDOS_INBOX_ADDRESS=defendos@example.com

# Only these senders can trigger the agent by email.
# Exact addresses and domains are accepted. Example:
# DEFENDOS_ALLOWED_SENDERS=me@example.com,@mycompany.com
DEFENDOS_ALLOWED_SENDERS=security@example.com

# Subject or body line must start with this token to trigger an email command.
DEFENDOS_EMAIL_TRIGGER_PREFIX=defendos:

# Ports that are expected to be public.
DEFENDOS_EXPECTED_PUBLIC_PORTS=22,80,443

# Your trusted SSH source IPs or CIDRs.
# Example: 203.0.113.10,198.51.100.0/24
DEFENDOS_TRUSTED_LOGIN_IPS=

# Alert threshold: info, low, medium, high, critical
DEFENDOS_ALERT_MIN_SEVERITY=high

# Suppress duplicate scheduled alerts during this window.
DEFENDOS_ALERT_SUPPRESS_MINUTES=120

# Optional extra env files already present on the machine.
# Leave blank unless you explicitly want DefendOS to read them.
DEFENDOS_EXTERNAL_ENV_FILES=

# Codex CLI settings.
CODEX_BIN=codex
DEFENDOS_CODEX_MODEL=
DEFENDOS_CODEX_TIMEOUT_SECONDS=900
DEFENDOS_CODEX_SCHEDULED_TIMEOUT_SECONDS=180
DEFENDOS_CODEX_SANDBOX=read-only
DEFENDOS_CODEX_ENABLED=true

# Email transport.
# Use "resend" if RESEND_API_KEY is available, or "smtp" otherwise.
DEFENDOS_EMAIL_PROVIDER=resend
DEFENDOS_INBOX_PROVIDER=imap

# Resend settings.
RESEND_API_KEY=
DEFENDOS_RESEND_FROM_EMAIL=DefendOS <defendos@example.com>
DEFENDOS_RESEND_REPLY_TO_EMAIL=defendos@example.com
DEFENDOS_RESEND_TEST_FROM_EMAIL=DefendOS Test <security@example.com>

# SMTP fallback settings.
DEFENDOS_SMTP_HOST=
DEFENDOS_SMTP_PORT=465
DEFENDOS_SMTP_USERNAME=
DEFENDOS_SMTP_PASSWORD=
DEFENDOS_SMTP_FROM=DefendOS <defendos@example.com>
DEFENDOS_SMTP_USE_SSL=true
DEFENDOS_SMTP_USE_STARTTLS=false

# IMAP fallback settings.
DEFENDOS_IMAP_HOST=
DEFENDOS_IMAP_PORT=993
DEFENDOS_IMAP_USERNAME=
DEFENDOS_IMAP_PASSWORD=
DEFENDOS_IMAP_FOLDER=INBOX
DEFENDOS_MAX_INBOX_MESSAGES=10

# Local dashboard.
DEFENDOS_DASHBOARD_HOST=127.0.0.1
DEFENDOS_DASHBOARD_PORT=8787
